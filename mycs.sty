% --- mycs.sty ---
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mycs}

% --- CODE HIGHLIGHTING ---
\RequirePackage{minted}

% --- GLOBAL MINTED SETTINGS ---
\setminted{
    linenos=true,         % show line numbers
    breaklines=true,      % wrap long lines
    frame=lines,          % draw lines at top and bottom of code blocks
    framesep=2mm,         % padding between frame and code
    baselinestretch=1.1,  % slight line spacing for readability
    fontsize=\small,      % slightly smaller font for code
    tabsize=4             % standard tab width
}

% --- ALGORITHMS & PSEUDOCODE ---
\RequirePackage{algorithm}
\RequirePackage{algpseudocode}

\endinput